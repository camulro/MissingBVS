corr <- factor(corr, levels = c("0.99",  "0.60"))
grupos <- factor(grupos, levels = c("G1", "G2", "G3"))
method <- factor(method, levels = c("SB", "BB", "PCA", "Oracle"))
res <- data.frame(probs, method, corr, grupos)
