library(BAS)
devtools::load_all()
BF.approx.BIC.glm
set.seed(123)
p <- 10 # number of predictors
n <- 100 # number of observations
q <- 4 # number of true covariates (q<p)
rho <- 0.5 # correlation between predictors
sigma.rho <- matrix(rho, nr = p, nc = p) # cov matrix to make corr approx rho
diag(sigma.rho) <- 1
X <- rmvnorm(n, mean = rep(0, p), sigma = sigma.rho)
library(mvtnorm)
set.seed(123)
p <- 10 # number of predictors
n <- 100 # number of observations
q <- 4 # number of true covariates (q<p)
rho <- 0.5 # correlation between predictors
sigma.rho <- matrix(rho, nr = p, nc = p) # cov matrix to make corr approx rho
diag(sigma.rho) <- 1
X <- rmvnorm(n, mean = rep(0, p), sigma = sigma.rho)
colnames(X) <- paste0("X", 1:p)
# response
intercept <- 1
beta <- c(rep(2,q), rep(0,p-q)) # true betas
theta <- intercept + X %*% beta # lineal predictor
prob <- 1 / (1 + exp(-theta))
y <- rbinom(n = n, size = 1, prob = prob) # Bernuilli with pi = prob, logistic regression
data.full <- data.frame(y = y, X)
formula <- y ~ .
null.model <- y ~ 1
# missings with ampute function from mice package
X.miss <- mice::ampute(X, prop = 0.2, # proportion of missingness
# patterns = NULL, # 0 indicates that a variable should have missings and 1, should remain complete
# freq = NULL, # relative frequency with which the patterns should occur
mech = "MAR" # missingness mechanism
)$amp
data <- data.frame(y = y, X.miss)
##mice and BIC method:
BF.approx.method = "BIC"
prior.models = "ScottBerger"
imp.mice.method = "pmm"
n.keep = 2^p
imp.seed = 123
n.imp = 4E2
family = binomial(link = "probit")
#with BAS (faster)
pruebabic <- missingBVS.glm(formula, null.model, data, family = family, BF.approx.method = BF.approx.method,
prior.models = prior.models, n.keep = n.keep,
imp.mice.method = imp.mice.method, n.imp = n.imp, imp.seed = imp.seed)
BF.approx.method = "gprior"
prior.betas = "gZellner"
prior.models = "ScottBerger"
imp.mice.method = "pmm"
n.keep = 2^p
imp.seed = 123
