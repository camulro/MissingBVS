H <- function(l,n) {
suma <- 0
for (i in 1:l) {
suma <- suma + (1+n)^((1-i)/2)*1/l
}
}
H(5,30)
suma
H <- function(l,n) {
suma <- 0
for (i in 1:l) {
suma <- suma + (1+n)^((1-i)/2)*1/l
}
suma
}
