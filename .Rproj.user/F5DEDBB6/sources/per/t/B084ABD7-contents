#to compare, this does not add the intercept to the imputed datasets, to use in Btest
mice.imputation2 <- function(X, nMC = 1E4, seed, imp.mice.method = "pmm") {
  #X is nxp with missing values coded as NA
  #nMC is the number of samples

  imput <- mice::mice(X,
                      meth = imp.mice.method,
                      m = nMC,
                      printFlag = FALSE,
                      seed = seed)

  imps <- mice::complete(imput, action = "all") #extracts all at once

  n <- nrow(X)
  p <- ncol(X)

  imputation.list <- list()
  for (s in seq_len(nMC)) {
    Xs <- as.matrix(imps[[s]])
    mu <- colMeans(Xs)
    imputation.list[[s]] <- Xs - matrix(mu, n, p, byrow = TRUE) # to center
  }

  return(imputation.list) #a list with the matrices centered imputed
}

